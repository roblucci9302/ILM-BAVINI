# Configuration du serveur Express
# Copier ce fichier vers .env

# Port du serveur
PORT=3000

# Environnement (development, production, test)
NODE_ENV=development

# Origines CORS autorisées (* pour tout autoriser)
CORS_ORIGIN=*

# Niveau de log (fatal, error, warn, info, debug, trace)
LOG_LEVEL=debug

# Base de données (si applicable)
# DATABASE_URL=

# Secrets (ne jamais commiter ces valeurs)
# JWT_SECRET=
# API_KEY=
