# Configuration Supabase
# Copier ce fichier vers .env et remplir avec vos vraies valeurs

# URL de votre projet Supabase (trouvable dans Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Clé publique anon (trouvable dans Settings > API)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optionnel : URL de redirection après auth (par défaut: window.location.origin)
# VITE_AUTH_REDIRECT_URL=http://localhost:3000

# Optionnel : Activer le mode debug
VITE_DEBUG=false
